config { type: "view", schema: "mkg_golden_stf", name: "OrgaoJulgador_Golden" }
SELECT
  UPPER(REPLACE(name, ' ', '_')) AS id_orgao,
  CASE WHEN name = 'Tribunal Pleno' THEN 'Art. 5º' ELSE 'Art. 9º' END AS competencia_ristf,
  CURRENT_TIMESTAMP() AS updated_at
FROM ${ref("orgaos_julgadores")}
WHERE name IS NOT NULL